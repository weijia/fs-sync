{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020"
  },
  "include": ["src"],
  "exclude": ["test", "node_modules", "dist"]
}
